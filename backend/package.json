{
  "name": "orquidario-yojo-backend",
  "version": "1.0.0",
  "description": "Backend do Orquidario Yojo - Vitrine virtual de orquideas",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "seed:admin": "node src/seeders/02-seed-admin-user.js",
    "seed:categorias": "node src/seeders/03-seed-categories.js",
    "seed:produtos": "node src/seeders/04-seed-products.js",
    "seed:all": "npm run seed:admin && npm run seed:categorias && npm run seed:produtos",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:reset": "docker compose down -v && docker compose up -d"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "sequelize": "^6.37.8"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
